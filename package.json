{
  "name": "monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
  "setup": "npm install",
  "dev": "npm run dev --prefix web",
  "build": "concurrently --raw \"npm run build --prefix web\"",
  "start": "concurrently --kill-others --raw \"npm run start --prefix pocketbase\"",
  "lint": "concurrently --raw \"npm run lint --prefix web\""
},
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "workspaces": [
    "apps/*"
  ],
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0"
  }
}
